                        <CheckBox x:Name="checkBoxEORLine3" Grid.Row="2" Grid.Column="2" Content="SAVE" VerticalAlignment="Center" Margin="0,0,0,6" />

                        <TextBlock x:Name="labelEORLine4" Grid.Row="3" Grid.Column="0" Text="LINE 4:" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <TextBox x:Name="textBoxEORLine4" Grid.Row="3" Grid.Column="1" Margin="0,0,8,6" />
                        <CheckBox x:Name="checkBoxEORLine4" Grid.Row="3" Grid.Column="2" Content="SAVE" VerticalAlignment="Center" Margin="0,0,0,6" />

                        <TextBlock x:Name="labelEORLine5" Grid.Row="4" Grid.Column="0" Text="LINE 5:" VerticalAlignment="Center" Margin="0,0,8,6" />
                        <TextBox x:Name="textBoxEORLine5" Grid.Row="4" Grid.Column="1" Margin="0,0,8,6" />
                        <CheckBox x:Name="checkBoxEORLine5" Grid.Row="4" Grid.Column="2" Content="SAVE" VerticalAlignment="Center" Margin="0,0,0,6" />

                        <TextBlock x:Name="labelEORLine6" Grid.Row="5" Grid.Column="0" Text="LINE 6:" VerticalAlignment="Center" />
