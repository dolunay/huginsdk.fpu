                            <ColumnDefinition Width="20*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="20*" />
                            <RowDefinition Height="60*" />
                            <RowDefinition Height="20*" />
                        </Grid.RowDefinitions>

                        <ProgressBar x:Name="progressBarSendProd" Grid.Row="1" Grid.Column="1" Height="24" />
                        <TextBlock x:Name="labelElapsedTime" Grid.Row="1" Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" />
                        <TextBlock x:Name="labelUnderProgressBar" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center" />
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="txtStatus"
                   Grid.Row="1"
                   Margin="0,8,0,0"
                   TextWrapping="Wrap"
                   FontSize="13"
                   Foreground="#444" />
    </Grid>
</UserControl>
