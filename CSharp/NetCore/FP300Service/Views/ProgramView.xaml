                        <CheckBox x:Name="checkBoxEORLine2" Grid.Row="1" Grid.Column="2" Content="SAVE" VerticalAlignment="Center" Margin="0,0,0,6" />

                        <TextBlock x:Name="labelEORLine3" Grid.Row="2" Grid.Column="0" Text="LINE 3:" VerticalAlignment="Center" Margin="0,0,8,6" />
