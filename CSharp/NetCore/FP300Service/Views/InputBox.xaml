<Window x:Class="FP300Service.Views.InputBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Giriş Yapınız"
        Width="384"
        Height="156"
        FontFamily="Microsoft Sans Serif"
        FontSize="11"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">
    <Grid>
        <Label x:Name="lblText" Content="Sayı Giriniz:" Margin="12,18,0,0" HorizontalAlignment="Left" VerticalAlignment="Top" />
        <TextBox x:Name="txtInput" Width="304" Height="22" Margin="64,54,16,0" HorizontalAlignment="Left" VerticalAlignment="Top" MaxLength="50" />
        <Button x:Name="btnOK"
                Width="138"
                Height="35"
                Margin="0,94,16,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                IsDefault="True"
                Content="Tamam"
                Click="BtnOK_OnClick" />
    </Grid>
</Window>
