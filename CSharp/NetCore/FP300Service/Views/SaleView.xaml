<UserControl x:Class="FP300Service.Views.SaleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="450"
             d:DesignWidth="800">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="4.5*" />
            <ColumnDefinition Width="1.3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,8,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="1.45*" />
                <RowDefinition Height="2.2*" />
                <RowDefinition Height="2.0*" />
                <RowDefinition Height="1.6*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" BorderBrush="#D9D9D9" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl x:Name="tbcStartDoc" Grid.Row="0" Height="30" SelectionChanged="TbcStartDoc_OnSelectionChanged">
                        <TabItem x:Name="tbStrtRcpt" Header="RECEIPT" />
                        <TabItem x:Name="tbStrtInvoice" Header="INVOICE TYPES" />
                        <TabItem x:Name="tabAdvance" Header="ADVANCE" />
                        <TabItem x:Name="tabParking" Header="OTOPARK" />
                        <TabItem x:Name="tabFood" Header="FOOD" />
                        <TabItem x:Name="tabCollectionInv" Header="COLLECTION INV" />
                        <TabItem x:Name="tabPageCrrAccountCollctn" Header="CUURENT ACCOUNT COLLECTION DOC" />
                        <TabItem x:Name="tabPageEDocument" Header="E-BELGE" />
                        <TabItem x:Name="tabPageDataTest" Header="DATA TEST" />
                        <TabItem x:Name="tabPageReturnDoc" Header="RETURN DOC" />
                    </TabControl>

                    <Grid Grid.Row="1">
                        <Grid x:Name="panelStartReceipt">
                            <Button x:Name="btnStartReceipt"
                                    Content="START DOCUMENT"
                                    Width="160"
                                    Height="52"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Click="BtnStartDocument_OnClick" />
                        </Grid>

                        <Grid x:Name="panelStartInvoice" Visibility="Collapsed" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="TCKN/VKN" />
                                    <TextBox x:Name="txtTCKN_VKN" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="SERIAL" />
                                    <TextBox x:Name="txtInvoiceSerial" />
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="ISSUE DATE" />
                                    <DatePicker x:Name="dpInvoiceIssueDate" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,8,0,8">
                                <TextBlock VerticalAlignment="Center" Text="INVOICE TYPE" Margin="0,0,8,0" />
                                <ComboBox x:Name="cbxInvTypes" Width="200" />
                            </StackPanel>

                            <Button x:Name="btnStartInvoice" Grid.Row="2" HorizontalAlignment="Right" Content="START INVOICE" Click="BtnStartInvoice_OnClick" />
                        </Grid>

                        <Grid x:Name="panelStartAdvance" Visibility="Collapsed" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="TCKN" />
                                    <TextBox x:Name="txtAdvanceTckn" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="NAME" />
                                    <TextBox x:Name="txtAdvanceName" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="AMOUNT" />
                                    <TextBox x:Name="txtAdvanceAmount" Text="0" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                                </StackPanel>
                            </Grid>

                            <Button x:Name="btnPaidDoc" Grid.Row="1" Margin="0,8,0,0" HorizontalAlignment="Right" Content="START ADVANCE" Click="BtnPaidDoc_OnClick" />
                        </Grid>

                        <Grid x:Name="panelStartParking" Visibility="Collapsed" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="PLATE" />
                                <TextBox x:Name="txtPlate" Text="34 FP 300" />
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="ENTRY DATE" />
                                <DatePicker x:Name="dpParkDate" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="ENTRY TIME" />
                                <TextBox x:Name="txtParkTime" Width="80" Text="12:00" />
                                <Button x:Name="btnStartParkDoc" Margin="0,8,0,0" Content="START DOCUMENT" Click="BtnStartParkDoc_OnClick" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="panelStartFood" Visibility="Collapsed">
                            <Button x:Name="buttonStartFoodDoc"
                                    Content="START DOCUMENT"
                                    Width="165"
                                    Height="58"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="16"
                                    Click="ButtonStartFoodDoc_OnClick" />
                        </Grid>

                        <Grid x:Name="panelStartCollection" Visibility="Collapsed" Margin="8">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="INVOICE NO" />
                                    <TextBox x:Name="txtCollectionSerial" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="AMOUNT" />
                                    <TextBox x:Name="txtCollectionAmount" Text="1" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="SUBSCRIBER NO" />
                                    <TextBox x:Name="txtSubscriberNo" />
                                </StackPanel>
                            </Grid>

                            <Grid Grid.Row="1" Margin="0,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="INSTITUTION" />
                                    <TextBox x:Name="txtInstitutionName" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock Text="INVOICE DATE" />
                                    <DatePicker x:Name="dpCollectionInvDate" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox x:Name="checkBoxComission" Margin="0,0,8,0" Checked="CheckBoxComission_OnChanged" Unchecked="CheckBoxComission_OnChanged" />
                                        <TextBlock VerticalAlignment="Center" Text="COMISSION" />
                                    </StackPanel>
                                    <TextBox x:Name="txtComission" Text="0" IsEnabled="False" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                                </StackPanel>
                            </Grid>

                            <Button x:Name="buttonStartCllctnDoc" Grid.Row="2" Content="START DOCUMENT" HorizontalAlignment="Left" Width="165" Click="ButtonStartCllctnDoc_OnClick" />
                        </Grid>

                        <Grid x:Name="panelStartCure" Visibility="Collapsed" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="2.3*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnPrintCurrAccHeader"
                                    Grid.Column="0"
                                    Content="START DOCUMENT"
                                    Margin="0,0,12,0"
                                    Click="BtnPrintCurrAccHeader_OnClick" />

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="TCKN/VKN" />
                                    <TextBox x:Name="txtCrrAccTcknVkn" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="CUSTOMER NAME" />
                                    <TextBox x:Name="txtCrrAccCustName" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="DOC SERIAL" />
                                    <TextBox x:Name="txtCrrAccDocSerial" />
                                </StackPanel>
                                <Grid Grid.Row="1" Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="DATE" />
                                        <DatePicker x:Name="dpCrrAccDate" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="AMOUNT" />
                                        <TextBox x:Name="txtCrrAccAmount" Text="1" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>

                        <Grid x:Name="panelStartEDocument" Visibility="Collapsed" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="buttonPrintEDocumentSample" Grid.Column="0" Content="PRINT E-DOCUMENT SAMPLE" Margin="0,0,12,0" Click="ButtonPrintEDocumentSample_OnClick" />

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="BELGE TİPİ" />
                                <ComboBox x:Name="comboBoxEDocumentDocTypes" Margin="0,0,0,8" />
                                <Button x:Name="buttonLoadInvoiceFile" Content="LOAD FILE" Width="112" Click="ButtonLoadInvoiceFile_OnClick" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="FILE" />
                                <TextBlock x:Name="labelInvoiceLinePath" TextWrapping="Wrap" Foreground="#666" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="panelStartDataTest" Visibility="Collapsed">
                            <Button x:Name="buttonSendTestData"
                                    Content="SEND TEST DATA"
                                    Width="170"
                                    Height="62"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"
                                    Margin="24"
                                    Click="ButtonSendTestData_OnClick" />
                        </Grid>

                        <Grid x:Name="panelStartReturnDoc" Visibility="Collapsed" Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*" />
                                <ColumnDefinition Width="2.4*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="buttonStartReturnDoc" Grid.Column="0" Content="START DOCUMENT" Margin="0,0,12,0" Click="ButtonStartReturnDoc_OnClick" />

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                                    <TextBlock Text="SERIAL" />
                                    <TextBox x:Name="txtRetDocSerial" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="ORDER NO" />
                                    <TextBox x:Name="txtRetDocOrderNo" />
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="DATE" />
                                    <DatePicker x:Name="dpRetDocDate" />
                                </StackPanel>
                                <Button x:Name="buttonAddCustomerRetDoc" Grid.Row="1" Grid.Column="1" Content="ADD CUSTOMER" Click="ButtonAddCustomerRetDoc_OnClick" />
                            </Grid>
                        </Grid>

                        <Grid x:Name="panelStartPlaceholder" Visibility="Collapsed">
                            <TextBlock Text="Bu sekme SaleUC ile uyumlu şekilde bir sonraki adımda detaylandırılacak."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#666" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="1" BorderBrush="#D9D9D9" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl x:Name="tbcSale" Grid.Row="0" Height="30" SelectionChanged="TbcSale_OnSelectionChanged">
                        <TabItem x:Name="tbpSale" Header="SALE" />
                        <TabItem x:Name="tbpVoidSale" Header="VOID SALE" />
                        <TabItem x:Name="tbpAdj" Header="ADJUSTMENT" />
                        <TabItem x:Name="tpgSaleDept" Header="DEPT SALE" />
                    </TabControl>

                    <Grid Grid.Row="1">
                        <Grid x:Name="panelSaleMain">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="1.6*" />
                                <ColumnDefinition Width="1.2*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnSale"
                                    Grid.Column="0"
                                    Margin="0,0,8,0"
                                    Content="SALE"
                                    Click="BtnAddItem_OnClick" />

                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="PLU:" />
                                <TextBox x:Name="txtPluId" Grid.Row="0" Grid.Column="1" Text="1" PreviewTextInput="IntegerInput_OnPreviewTextInput" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="QUANTITY:" />
                                <TextBox x:Name="txtQuantity" Grid.Row="1" Grid.Column="1" Text="1" PreviewTextInput="DecimalInput_OnPreviewTextInput" />

                                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                    <CheckBox x:Name="checkBoxForPrice" Margin="0,0,8,0" Checked="CheckBoxForPrice_OnChanged" Unchecked="CheckBoxForPrice_OnChanged" />
                                    <TextBlock x:Name="lblAmount" VerticalAlignment="Center" Text="PRICE" />
                                </StackPanel>
                                <TextBox x:Name="txtPrice" Grid.Row="2" Grid.Column="1" Text="1,00" IsEnabled="False" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                            </Grid>

                            <Grid Grid.Column="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                                    <TextBlock VerticalAlignment="Center" Text="SAVE_SALE" Margin="0,0,8,0" />
                                    <CheckBox x:Name="cbxSaveAndSale" />
                                </StackPanel>

                                <Grid Grid.Row="1">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.1*" />
                                        <ColumnDefinition Width="1*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="BARCODE" />
                                    <TextBox x:Name="txtBarcode" Grid.Row="0" Grid.Column="1" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="DEP. ID" />
                                    <TextBox x:Name="txtDeptId" Grid.Row="1" Grid.Column="1" Text="1" PreviewTextInput="IntegerInput_OnPreviewTextInput" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="PLU NAME" />
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                        <TextBox x:Name="txtPluName" Width="100" />
                                        <CheckBox x:Name="checkBoxWeighable" Content="WEIGHABLE" Margin="6,0,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Grid>

                        <Grid x:Name="panelVoidSale" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnVoidSale" Grid.Column="0" Margin="0,0,8,0" Content="VOID SALE" Click="BtnVoidSale_OnClick" />

                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                    <TextBlock x:Name="lblVoidPlu" VerticalAlignment="Center" Text="PLU ID" />
                                    <CheckBox x:Name="cbxVoidDept" Margin="12,0,0,0" VerticalAlignment="Center" Content="Void Department" Checked="CbxVoidDept_OnChanged" Unchecked="CbxVoidDept_OnChanged" />
                                </StackPanel>
                                <TextBox x:Name="txtVoidPluId" Text="1" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="QUANTITY" />
                                <TextBox x:Name="txtVoidQuantity" Text="1" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                            </StackPanel>
                            <StackPanel x:Name="panelVoidDeptName" Grid.Column="3" Visibility="Collapsed">
                                <TextBlock x:Name="lblVoidDeptName" Text="DEPT NAME" />
                                <TextBox x:Name="txtVoidDeptName" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="panelAdjustment" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,8,0">
                                <RadioButton x:Name="rbtnFee" Content="FEE" IsChecked="True" Margin="0,0,12,0" />
                                <RadioButton x:Name="rbtnDiscount" Content="DISCOUNT" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                                <CheckBox x:Name="cbxPerc" Content="PERCENTAGE" Margin="0,0,8,0" />
                                <TextBox x:Name="txtAdjAmount" Width="100" Text="0" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                            </StackPanel>
                            <Button x:Name="btnAdjust" Grid.Column="2" Content="ADJUST" Click="BtnAdjust_OnClick" />
                        </Grid>

                        <Grid x:Name="panelSaleDept" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1.6*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnSaleDept" Grid.Column="0" Margin="0,0,8,0" Content="SALE" Click="BtnSaleDept_OnClick" />

                            <Grid Grid.Column="1" Margin="0,0,8,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="DEP. ID" />
                                <TextBox x:Name="txtDeptSaleId" Grid.Row="0" Grid.Column="1" Text="1" PreviewTextInput="IntegerInput_OnPreviewTextInput" />

                                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="QUANTITY" />
                                <TextBox x:Name="txtDeptSaleQuantity" Grid.Row="1" Grid.Column="1" Text="1" PreviewTextInput="DecimalInput_OnPreviewTextInput" />

                                <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="PRICE" />
                                <TextBox x:Name="txtDeptSalePrice" Grid.Row="2" Grid.Column="1" Text="1,00" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                            </Grid>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="DEPT NAME" Margin="0,0,0,8" />
                                <TextBox x:Name="txtDeptSaleName" Margin="0,0,0,8" />
                                <CheckBox x:Name="cbxDeptSaleWeighable" Content="WEIGHABLE" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="2" BorderBrush="#D9D9D9" BorderThickness="1" Padding="6" Margin="0,0,0,8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl x:Name="tbcPayment" Grid.Row="0" Height="30" SelectionChanged="TbcPayment_OnSelectionChanged">
                        <TabItem x:Name="tbpPay1" Header="CASH PAYMENTS" />
                        <TabItem x:Name="tbpPayEFT" Header="EFT PAYMENT" />
                        <TabItem x:Name="tbpVoidPay" Header="VOID PAYMENT" />
                        <TabItem x:Name="tabRefund" Header="EFT REFUND" />
                        <TabItem x:Name="tabPageBankList" Header="BANK LIST" />
                        <TabItem x:Name="tabPageEftSlipCopy" Header="EFT SLIP COPY" />
                        <TabItem x:Name="tabSlipExternal" Header="EXTERNAL SLIP" />
                    </TabControl>

                    <Grid Grid.Row="1">
                        <Grid x:Name="panelCashPayment">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnPayment" Grid.Column="0" Margin="0,0,8,0" Content="PAYMENT" Click="BtnPayment_OnClick" />

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*" />
                                    <ColumnDefinition Width="1*" />
                                    <ColumnDefinition Width="1*" />
                                </Grid.ColumnDefinitions>

                                <TextBlock x:Name="lblPayAmount" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="PAYMENT AMOUNT" />
                                <TextBox x:Name="txtPaymentAmount" Grid.Row="0" Grid.Column="2" Text="1,00" PreviewTextInput="DecimalInput_OnPreviewTextInput" />

                                <TextBlock x:Name="lblPayType" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="PAYMENT TYPE" />
                                <ComboBox x:Name="cbxPaymentType" Grid.Row="1" Grid.Column="1" SelectionChanged="CbxPaymentType_OnSelectionChanged" />
                                <StackPanel Grid.Row="1" Grid.Column="2">
                                    <TextBlock x:Name="lblPayIndx" Text="INDEX" />
                                    <ComboBox x:Name="cbxSubPayments" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Grid x:Name="panelEftPayment" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock x:Name="lblEftAmount" Text="AMOUNT" />
                                <TextBox x:Name="txtEftAmount" Text="0" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock x:Name="lblInstallment" Text="INSTALLMENT" />
                                <TextBox x:Name="txtInstallment" Text="0" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="lblCardNum" Text="CARD NUMBER" />
                                <TextBox x:Name="txtCardNumber" />
                            </StackPanel>
                            <StackPanel Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,60,0,0">
                                <Button x:Name="btnCardQuery" Margin="0,0,8,0" Content="CHECK CARD" Click="BtnCardQuery_OnClick" />
                                <Button x:Name="btnEFTAuthorization" Content="EFT PAYMENT" Click="BtnEftAuthorization_OnClick" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="panelVoidPay" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <TextBlock x:Name="lblVoidPayIndex" VerticalAlignment="Center" Margin="0,0,8,0" Text="PAYMENT INDEX" />
                                <TextBox x:Name="txtVoidPayIndex" Width="120" Text="1" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                            </StackPanel>
                            <StackPanel Grid.Row="1" Orientation="Vertical" Margin="0,0,0,8">
                                <CheckBox x:Name="checkBoxVoidEft" Margin="0,0,0,6" Content="VOID EFT" Checked="CheckBoxVoidEft_OnCheckedChanged" Unchecked="CheckBoxVoidEft_OnCheckedChanged" />
                                <Grid x:Name="panelVoidEft">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock x:Name="lblAcquierId" Text="ACQUIER ID" />
                                        <TextBox x:Name="txtAcquierId" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                        <TextBlock x:Name="lblBatchNo" Text="BATCH NO" />
                                        <TextBox x:Name="txtBatchNo" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock x:Name="lblStanNo" Text="STAN NO" />
                                        <TextBox x:Name="txtStanNo" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                            <Button x:Name="btnVoidPayment" Grid.Row="2" Content="VOID PAYMENT" HorizontalAlignment="Right" Click="BtnVoidPayment_OnClick" />
                        </Grid>

                        <Grid x:Name="panelRefund" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>

                            <Button x:Name="btnRefund" Grid.Column="0" Margin="0,0,8,0" Content="REFUND" Click="BtnRefund_OnClick" />
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock x:Name="lblRefundAcquierId" Text="ACQUIER ID" />
                                <TextBox x:Name="txtAcquierIdRefund" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock x:Name="lblRefundAmount" Text="AMOUNT" />
                                <TextBox x:Name="txtRefundAmount" Text="0" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="panelBankList" Visibility="Collapsed">
                            <Button x:Name="btnBankList" Content="GET BANK LIST" Width="165" Height="58" HorizontalAlignment="Left" VerticalAlignment="Top" Click="BtnBankList_OnClick" />
                        </Grid>

                        <Grid x:Name="panelEftSlipCopy" Visibility="Collapsed">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button x:Name="buttonGetEFTSlipCopy" Content="GET SLIPCOPY" Width="134" Height="74" Margin="0,0,16,0" Click="ButtonGetEFTSlipCopy_OnClick" />
                                <CheckBox x:Name="checkBoxSlpCpyZnoRcptNo" Content="Z No-Fiş No ile Al" Checked="CheckBoxSlpCpyZnoRcptNo_OnChanged" Unchecked="CheckBoxSlpCpyZnoRcptNo_OnChanged" />
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock Text="ACQUIER ID" />
                                    <TextBox x:Name="txtSlipCopyAcquierId" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                    <TextBlock x:Name="lblSlipCopyBatchNo" Text="BATCH NO" />
                                    <TextBox x:Name="txtSlipCopyBatchNo" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock x:Name="lblSlipCopyStanNo" Text="STAN NO" />
                                    <TextBox x:Name="txtSlipCopyStanNo" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                </StackPanel>
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                    <TextBlock x:Name="lblSlipCopyZNo" Text="Z NO" IsEnabled="False" />
                                    <TextBox x:Name="txtSlipCopyZNo" IsEnabled="False" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock x:Name="lblSlipCopyReceiptNo" Text="RECEIPT NO" IsEnabled="False" />
                                    <TextBox x:Name="txtSlipCopyReceiptNo" IsEnabled="False" PreviewTextInput="IntegerInput_OnPreviewTextInput" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <Grid x:Name="panelExternalSlip" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="2*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnSendSlip" Grid.Column="0" Content="SEND SLIP" Click="BtnSendSlip_OnClick" />
                            <GroupBox Grid.Column="1" Header="Slip Type" Margin="8,0">
                                <StackPanel>
                                    <RadioButton x:Name="rbtnSlipTypeCustomer" Content="Customer" IsChecked="True" />
                                    <RadioButton x:Name="rbtnSlipTypeMerchant" Content="Merchant" />
                                    <RadioButton x:Name="rbtnSlipTypeError" Content="Error" />
                                </StackPanel>
                            </GroupBox>
                            <GroupBox Grid.Column="2" Header="Slip Lines">
                                <TextBox x:Name="txtSlipLines" AcceptsReturn="True" TextWrapping="Wrap" />
                            </GroupBox>
                        </Grid>

                        <Grid x:Name="panelPaymentPlaceholder" Visibility="Collapsed">
                            <TextBlock Text="Bu ödeme sekmesi SaleUC ile uyumlu şekilde sonraki adımda detaylandırılacak."
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#666" />
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Row="3" BorderBrush="#D9D9D9" BorderThickness="1" Padding="6">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TabControl x:Name="tbcFooter" Grid.Row="0" Height="30" SelectionChanged="TbcFooter_OnSelectionChanged">
                        <TabItem x:Name="tbpNotes" Header="FOOTER NOTES" />
                        <TabItem x:Name="tbpExtra" Header="FOOTER NOTE EXTRA" />
                        <TabItem x:Name="tabPageBarcode" Header="BARCODE" />
                        <TabItem x:Name="tabPageStoppage" Header="STOPPAGE" />
                    </TabControl>

                    <Grid Grid.Row="1">
                        <Grid x:Name="panelFooterNotes">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="3*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnRemark" Grid.Column="0" Margin="0,0,8,0" Content="REMARK" Click="BtnRemark_OnClick" />
                            <TextBox x:Name="txtRemarkLine" Grid.Column="1" AcceptsReturn="True" TextWrapping="Wrap" />
                        </Grid>

                        <Grid x:Name="panelFooterExtra" Visibility="Collapsed">
                            <Button x:Name="btnOpenDrawer"
                                    Width="165"
                                    Height="46"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    Content="OPEN DRAWER"
                                    Click="BtnOpenDrawer_OnClick" />
                        </Grid>

                        <Grid x:Name="panelFooterBarcode" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="1.4*" />
                                <ColumnDefinition Width="1.7*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="btnRcptBarcode" Grid.Column="0" Content="PRINT BARCODE" Click="BtnRcptBarcode_OnClick" />
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="BARCODE TYPE" />
                                <ComboBox x:Name="comboBoxBarcodeTypes">
                                    <ComboBoxItem Content="DEFAULT" IsSelected="True" />
                                    <ComboBoxItem Content="QR" />
                                    <ComboBoxItem Content="CODE128" />
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="BARCODE" />
                                <TextBox x:Name="txtRcptBarcode" />
                            </StackPanel>
                        </Grid>

                        <Grid x:Name="panelFooterStoppage" Visibility="Collapsed">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="0.9*" />
                                <ColumnDefinition Width="1.5*" />
                            </Grid.ColumnDefinitions>
                            <Button x:Name="buttonStoppage" Grid.Column="0" Content="SEND STOPPAGE" Click="ButtonStoppage_OnClick" />
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="AMOUNT" />
                                <TextBox x:Name="txtStoppageAmount" Text="0" PreviewTextInput="DecimalInput_OnPreviewTextInput" />
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </Border>

            <TextBlock x:Name="txtStatus" Grid.Row="4" Margin="0,8,0,0" TextWrapping="Wrap" FontSize="13" Foreground="#444" />
        </Grid>

        <StackPanel Grid.Column="1">
            <Button x:Name="btnAutoPrintJsonDept" Content="AUTO PRINT JSON DEPT" Margin="0,0,0,8" Click="BtnAutoPrintJsonDept_OnClick" />
            <Button x:Name="btnAutoPrintJsonPlu" Content="AUTO PRINT JSON PLU" Margin="0,0,0,8" Click="BtnAutoPrintJsonPlu_OnClick" />
            <Button x:Name="btnReceiptInfo" Content="RECEIPT INFO" Margin="0,0,0,8" Click="BtnReceiptInfo_OnClick" />
            <Button x:Name="btnPrintJsonDocument" Content="PRINT JSON" Margin="0,0,0,8" Click="BtnPrintJsonDocument_OnClick" />
            <Button x:Name="btnPrintJsonDept" Content="PRINT JSON DEPT" Margin="0,0,0,8" Click="BtnPrintJsonDept_OnClick" />
            <Button x:Name="btnSubtotal" Content="SUBTOTAL" Margin="0,0,0,8" Click="BtnSubtotal_OnClick" />
            <Button x:Name="btnCorrect" Content="CORRECT" Margin="0,0,0,8" Click="BtnCorrect_OnClick" />
            <Button x:Name="btnCloseReceipt" Content="CLOSE DOCUMENT" Margin="0,0,0,8" Click="BtnCloseDocument_OnClick" />
            <Button x:Name="btnVoidReceipt" Content="VOID DOCUMENT" Margin="0,0,0,8" Click="BtnVoidDocument_OnClick" />
            <Button x:Name="btnPrintSalesDocument" Content="PRINT SALE DOCUMENT" Margin="0,0,0,8" Click="BtnPrintSalesDocument_OnClick" />
        </StackPanel>
    </Grid>
</UserControl>
