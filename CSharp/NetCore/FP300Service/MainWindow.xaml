<Window x:Class="FP300NetCoreService.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FP300 Servis"
        FontFamily="Microsoft Sans Serif"
        FontSize="12"
        Height="900"
        Width="1500"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        WindowState="Maximized">
    <Window.Resources>
        <DataTemplate x:Key="MenuItemTemplate">
            <Grid Margin="6,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="22"
                        Height="22"
                        CornerRadius="2"
                        BorderBrush="#C8C8C8"
                        BorderThickness="1"
                        Background="#F4F4F4"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding Glyph}"
                               FontFamily="Segoe MDL2 Assets"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>

                <TextBlock Grid.Column="1"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center"
                           Text="{Binding Text}" />
            </Grid>
        </DataTemplate>

        <Style TargetType="Button">
            <Setter Property="BorderBrush" Value="#ACACAC" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4,1" />
            <Setter Property="Background">
                <Setter.Value>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#FDFDFD" Offset="0" />
                        <GradientStop Color="#E3E3E3" Offset="1" />
                    </LinearGradientBrush>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="BorderBrush" Value="#7F9DB9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="2,1,2,1" />
        </Style>
        <Style TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Border x:Name="ItemBorder"
                                Background="White"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#D0D0D0" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#F8F8F8" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#A9A9A9" />
                                <Setter TargetName="ItemBorder" Property="Background" Value="#ECECEC" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="120" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="264" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0"
                Grid.Column="0"
                Margin="4,5,4,5"
                Background="White"
                BorderBrush="#BFBFBF"
                BorderThickness="1">
            <Image x:Name="imgLogo" Source="/Assets/Images/FP300 All mini.png"
                   Stretch="Uniform"
                   Margin="8" />
        </Border>

        <Border Grid.Row="0"
                Grid.Column="1"
                Margin="4,5,4,5"
                Background="White"
                BorderBrush="#BFBFBF"
                BorderThickness="1">
        <Grid Margin="8,6,8,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="57.54082*" />
                <ColumnDefinition Width="42.45918*" />
            </Grid.ColumnDefinitions>

            <TabControl x:Name="tabConn" Grid.Column="0" Margin="0,0,8,0">
                <TabItem x:Name="tabTcp" Header="TCP/IP">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="lblTcpIp" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,6" Text="IP :" />
                        <TextBox x:Name="txtTCPIP" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" Text="127.0.0.1" />

                        <TextBlock x:Name="lblTcpPort" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="Port :" />
                        <TextBox x:Name="txtTcpPort" Grid.Row="1" Grid.Column="1" Text="4444" />
                    </Grid>
                </TabItem>

                <TabItem x:Name="tabComPort" Header="SERIAL PORT">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="lblComPort" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,6" Text="PORT :" />
                        <ComboBox x:Name="cmbPorts" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" DropDownOpened="CmbPorts_OnDropDownOpened" />

                        <TextBlock x:Name="lblBaudrate" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="BAUDRATE :" />
                        <TextBox x:Name="txtBaudrate" Grid.Row="1" Grid.Column="1" Text="115200" />
                    </Grid>
                </TabItem>
            </TabControl>

            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock x:Name="lblFiscalId" Text="FISCAL ID :" Margin="0,0,0,4" />
                    <TextBox x:Name="txtFiscalId" Text="FP12345678" />
                </StackPanel>
                <Button x:Name="btnConnect"
                        Grid.Column="1"
                        Content="CONNECT"
                        Click="BtnConnect_OnClick"
                         MinHeight="56" />
            </Grid>
        </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="4,5,4,5"
                Background="White"
                BorderBrush="#BFBFBF"
                BorderThickness="1">
            <ListView x:Name="lvievMenu"
                      BorderThickness="0"
                      Background="White"
                      ItemTemplate="{StaticResource MenuItemTemplate}"
                      SelectionChanged="LvievMenu_OnSelectionChanged" />
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Margin="4,5,4,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="57.66283*" />
                <ColumnDefinition Width="42.33717*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#BFBFBF" BorderThickness="1" Margin="0,0,8,0" Padding="12" Background="White">
                <ContentControl x:Name="mainContentHost" />
            </Border>

            <TextBox x:Name="txtLog"
                     Grid.Column="1"
                     Background="Black"
                     Foreground="White"
                      FontFamily="Courier New"
                     FontSize="13"
                     IsReadOnly="True"
                      TextWrapping="NoWrap"
                     AcceptsReturn="True"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled" />
        </Grid>
    </Grid>
</Window>
